{
  "expo": {
    "name": "SUTRA",
    "slug": "sutra",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "sutra",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.purama.sutra",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "SUTRA utilise la caméra pour filmer tes vidéos et prouver tes missions.",
        "NSPhotoLibraryUsageDescription": "SUTRA accède à ta galerie pour importer des médias dans tes vidéos.",
        "NSMicrophoneUsageDescription": "SUTRA utilise le micro pour enregistrer la voix de tes vidéos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "dev.purama.sutra",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#8B5CF6"
        }
      ],
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://sutra.purama.dev"
      },
      "eas": {
        "projectId": "sutra-mobile"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/sutra-mobile"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
