{
  "crons": [
    {
      "path": "/api/cron/contest-weekly",
      "schedule": "0 12 * * 1"
    },
    {
      "path": "/api/cron/contest-monthly",
      "schedule": "0 12 1 * *"
    },
    {
      "path": "/api/cron/contest-judge",
      "schedule": "59 23 28-31 * *"
    },
    {
      "path": "/api/cron/auto-plan",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/auto-learn",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/cron/auto-trends",
      "schedule": "0 6 * * *"
    }
  ],
  "functions": {
    "src/app/api/cron/contest-judge/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/cron/contest-weekly/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/contest-monthly/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/auto-plan/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/auto-learn/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/auto-trends/route.ts": {
      "maxDuration": 180
    },
    "src/app/api/auto/generate/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/auto/publish/route.ts": {
      "maxDuration": 120
    }
  }
}
